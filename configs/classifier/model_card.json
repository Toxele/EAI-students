{
  "model_name": "nornikel_ore_classifier_3class",
  "task": "image_classification",
  "framework": "pytorch",
  "checkpoint_path": "artifacts/runs/classifier_baseline/best.pt",
  "model": {
    "architecture": "resnet18",
    "input_channels": 3,
    "image_size": 384
  },
  "classes": [
    {
      "id": 0,
      "name": "ordinary",
      "display_name": "рядовая руда"
    },
    {
      "id": 1,
      "name": "thin",
      "display_name": "труднообогатимая руда"
    },
    {
      "id": 2,
      "name": "talc",
      "display_name": "оталькованная руда"
    }
  ],
  "preprocessing": {
    "resize": [384, 384],
    "color_mode": "RGB",
    "normalization": {
      "mean": [0.485, 0.456, 0.406],
      "std": [0.229, 0.224, 0.225]
    }
  },
  "postprocessing": {
    "activation": "softmax",
    "return_probabilities": true,
    "top_k": 3,
    "uncertain_policy": {
      "enabled": true,
      "min_confidence": 0.55,
      "max_top2_gap": 0.12,
      "label": "uncertain"
    }
  }
}
