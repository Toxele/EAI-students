{
  "manifest": {
    "root": "spbgu_data",
    "output_csv": "artifacts/manifests/spbgu_segmentation_manifest.csv",
    "input_kind": "txt",
    "val_fraction": 0.25,
    "seed": 42
  },
  "training": {
    "seed": 42,
    "device": "auto",
    "dataset_csv": "artifacts/manifests/spbgu_segmentation_manifest.csv",
    "run_dir": "notebooks/spbgu_unet_experiments/outputs/runs/spbgu_unet_resnet34_txt",
    "data": {
      "image_size": 512,
      "batch_size": 2,
      "num_workers": 0,
      "augment": true
    },
    "augmentation": {
      "hflip_p": 0.5,
      "vflip_p": 0.5,
      "max_rotate_degrees": 20,
      "brightness": 0.12,
      "contrast": 0.22,
      "clahe_p": 0.45,
      "noise_p": 0.35,
      "noise_sigma_min": 1.0,
      "noise_sigma_max": 8.0,
      "blur_p": 0.15,
      "blur_kernel_sizes": [3, 5]
    },
    "model": {
      "name": "smp_unet",
      "encoder_name": "resnet34",
      "encoder_weights": "imagenet",
      "in_channels": 3,
      "classes": 1
    },
    "loss": {
      "bce_weight": 0.35,
      "dice_weight": 0.55,
      "focal_weight": 0.1,
      "focal_alpha": 0.65,
      "focal_gamma": 2.0
    },
    "optimizer": {
      "lr": 0.00025,
      "weight_decay": 0.0001
    },
    "trainer": {
      "epochs": 40,
      "amp": true,
      "save_every": 1,
      "early_stopping_patience": 8,
      "threshold": 0.5,
      "monitor": "dice",
      "roc_auc": true
    },
    "cross_validation": {
      "folds": 4,
      "run_dir": "notebooks/spbgu_unet_experiments/outputs/runs/spbgu_unet_resnet34_txt_4fold"
    }
  },
  "prediction": {
    "checkpoint_path": "notebooks/spbgu_unet_experiments/outputs/runs/spbgu_unet_resnet34_txt/best.pt",
    "manifest_csv": "artifacts/manifests/spbgu_segmentation_manifest.csv",
    "output_dir": "notebooks/spbgu_unet_experiments/outputs/predictions/spbgu_unet_resnet34_txt",
    "device": "auto",
    "threshold": 0.5
  }
}
