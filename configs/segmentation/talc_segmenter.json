{
  "seed": 42,
  "device": "auto",
  "dataset_csv": "artifacts/manifests/talc_segmentation_dataset.csv",
  "run_dir": "artifacts/runs/talc_segmenter",
  "mlflow": {
    "enabled": true,
    "tracking_uri": "file:artifacts/mlruns",
    "experiment": "nornikel_talc_segmentation",
    "run_name": "tiny_unet_manual_masks"
  },
  "data": {
    "image_size": 384,
    "batch_size": 4,
    "num_workers": 0,
    "augment": true
  },
  "augmentation": {
    "hflip_p": 0.5,
    "vflip_p": 0.2,
    "max_rotate_degrees": 12,
    "brightness": 0.18,
    "contrast": 0.18,
    "saturation": 0.12,
    "gamma": 0.08,
    "gray_domain_p": 0.35,
    "gray_saturation_min": 0.08,
    "gray_saturation_max": 0.45,
    "gray_brightness_min": 0.45,
    "gray_brightness_max": 0.85,
    "gray_contrast_min": 0.55,
    "gray_contrast_max": 0.95,
    "gray_blue_gain_max": 1.12,
    "gray_red_gain_min": 0.88
  },
  "model": {
    "name": "tiny_unet",
    "in_channels": 3,
    "base_channels": 32
  },
  "loss": {
    "bce_weight": 0.4,
    "dice_weight": 0.5,
    "focal_weight": 0.1,
    "focal_alpha": 0.75,
    "focal_gamma": 2.0
  },
  "optimizer": {
    "name": "adamw",
    "lr": 0.0003,
    "weight_decay": 0.0001
  },
  "trainer": {
    "epochs": 30,
    "amp": true,
    "save_every": 1,
    "early_stopping_patience": 7,
    "threshold": 0.5,
    "roc_auc": true
  }
}
